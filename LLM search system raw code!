    "# import necessary modules\n",
    "import json\n",
    "import ollama\n",
    "import chromadb"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "80d48689-c54a-4086-a5a8-4225e989bd6f",
   "metadata": {},
   "outputs": [],
   "source": [
    "# have python read the cleaned json data \n",
    "\n",
    "with open(\"/Users/alexgiles/Downloads/bookssample.json\") as f:\n",
    "    books = json.load(f)\n",
    "# test that it worked sucesfully\n",
    "print(books[1])  "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "18c2c7e2-e61b-4474-b39c-35a452ec7f0c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# add embeddings to the dataset\n",
    "def embed_text(text):\n",
    "    response = ollama.embeddings(\n",
    "        model=\"nomic-embed-text\",\n",
    "        input= books\n",
    "    )\n",
    "    return response[\"embedding\"]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d1352041-198f-4126-aa75-fa1cbf8bf778",
   "metadata": {},
   "outputs": [],
   "source": [
    "# establish datacollection with chromadb\n",
    "client = chromadb.Client()\n",
    "collection = client.get_or_create_collection(name=\"books\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "928de9bf-6a55-4b7e-a192-5f97bee4b643",
   "metadata": {},
   "outputs": [],
   "source": [
    "# assign each book in the sample with a vector, change '100' for a larger dataset\n",
    "\n",
    "def format_book(book):\n",
    "    return f\"\"\"{book}\"\"\"  \n",
    "\n",
    "def get_embedding(text):\n",
    "    return ollama.embeddings(\n",
    "        model=\"nomic-embed-text\",\n",
    "        prompt=text\n",
    "    )[\"embedding\"]\n",
    "\n",
    "for i, book in enumerate(books[:100]):\n",
    "    text = format_book(book)\n",
    "    embedding = get_embedding(text)\n",
    "\n",
    "    collection.add(\n",
    "        documents=[text],\n",
    "        embeddings=[embedding],\n",
    "        metadatas=[book],\n",
    "        ids=[str(i)]\n",
    "    )\n",
    "\n",
    "print(\"Sample assigned vector\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "94add135-66f0-4db0-98b8-30a79edd74af",
   "metadata": {},
   "outputs": [],
   "source": [
