    "query = \"european fantasy\"\n",
    "\n",
    "query_embedding = get_embedding(query)\n",
    "\n",
    "results = collection.query(\n",
    "    query_embeddings=[query_embedding],\n",
    "    n_results=1\n",
    ")\n",
    "\n",
    "results[\"metadatas\"][0]"
